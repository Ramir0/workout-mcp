# Docker-specific environment variables for docker-compose.prod.yml
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# DATABASE_URL uses the Docker service name 'db' instead of localhost
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@db:5432/workout_mcp

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Hevy settings
HEVY_API_KEY=your-hevy-api-key
HEVY_BASE_URL=https://api.hevyapp.com
HEVY_WEBHOOK_SECRET=your-hevy-webhook-secret
HEVY_SYNC_INTERVAL_SECONDS=3600
