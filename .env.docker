# Docker-specific environment variables for docker-compose.prod.yml
# These are used by docker-compose.yml for variable interpolation
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# CORS configuration
CORS_ORIGINS=http://127.0.0.1:9091,https://subdomain.yourdomain.com

# Hevy settings
HEVY_API_KEY=your-hevy-api-key
HEVY_BASE_URL=https://api.hevyapp.com
HEVY_SYNC_INTERVAL_SECONDS=3600
