# Database (used by pydantic-settings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workout_mcp
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workout_mcp_test

# Docker Compose (not read by pydantic-settings — used by docker-compose.yml)
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# App
APP_PORT=9090
MCP_PORT=9091

# Hevy API (optional — required for webhook sync and automatic workout fetching)
HEVY_API_KEY=your-hevy-api-key
# When set, all REST API endpoints require the Authorization: ApiKey <key> header with this exact value
REST_API_KEY=your-rest-api-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
